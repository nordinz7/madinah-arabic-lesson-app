{
  "type": "question",
  "content": "ما هذا؟",
  "translit": "mā hādhā?",
  "meaning": "What is this?",
  "order": 2,
  "notes": "ما means \"what\" when asking about non-human things.\nThe prefix أ at the start of a sentence (أهذا...؟) turns it into a yes/no question (\"is this...?\").\nAnswers use نَعَمْ (yes) or لا (no).",
  "examples": [
    { "prompt": "ما هذا؟", "answer": "هذا بَيْتٌ.", "meaning": "What is this? — This is a house." },
    { "prompt": "أهذا بَيْتٌ؟", "answer": "نَعَمْ، هذا بَيْتٌ.", "meaning": "Is this a house? — Yes, this is a house." },
    { "prompt": "ما هذا؟", "answer": "هذا قَمِيصٌ.", "meaning": "What is this? — This is a shirt." },
    { "prompt": "أهذا سَرِيرٌ؟", "answer": "لا، هذا كُرْسِيٌّ.", "meaning": "Is this a bed? — No, this is a chair." },
    { "prompt": "أهذا مِفْتَاحٌ؟", "answer": "لا، هذا قَلَمٌ.", "meaning": "Is this a key? — No, this is a pen." },
    { "prompt": "ما هذا؟", "answer": "هذا نَجْمٌ.", "meaning": "What is this? — This is a star." }
  ],
  "vocab": [
    { "arabic": "قَمِيصٌ", "translit": "qamīṣun", "meaning": "shirt", "gender": "m", "plural": "قُمْصَان", "pluralTranslit": "qumṣān" },
    { "arabic": "نَجْمٌ", "translit": "najmun", "meaning": "star", "gender": "m", "plural": "نُجُوم", "pluralTranslit": "nujūm" }
  ]
},
