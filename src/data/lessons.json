{
  "type": "topic",
  "content": "هذا",
  "translit": "hādhā",
  "meaning": "this (masculine, near)",
  "order": 1,
  "notes": "هذا is the demonstrative pronoun for a single masculine object that is near.\nNouns appear with tanwīn (final ـٌ /-un/), the indefinite case ending — \"a door\", \"a mosque\", etc.\nUse هذا for masculine nouns; the feminine form (هذه) is introduced in Lesson 6.",
  "examples": [
    { "prompt": "هذا بَابٌ.", "translit": "hādhā bābun", "meaning": "This is a door." },
    { "prompt": "هذا مَسْجِدٌ.", "translit": "hādhā masjidun", "meaning": "This is a mosque." },
    { "prompt": "هذا بَيْتٌ.", "translit": "hādhā baytun", "meaning": "This is a house." },
    { "prompt": "هذا مِفْتَاحٌ.", "translit": "hādhā miftāḥun", "meaning": "This is a key." },
    { "prompt": "هذا قَلَمٌ.", "translit": "hādhā qalamun", "meaning": "This is a pen." },
    { "prompt": "هذا كِتَابٌ.", "translit": "hādhā kitābun", "meaning": "This is a book." },
    { "prompt": "هذا كُرْسِيٌّ.", "translit": "hādhā kursiyyun", "meaning": "This is a chair." },
    { "prompt": "هذا سَرِيرٌ.", "translit": "hādhā sarīrun", "meaning": "This is a bed." },
    { "prompt": "هذا مَكْتَبٌ.", "translit": "hādhā maktabun", "meaning": "This is a desk." }
  ],
