{
  "type": "question",
  "content": "مَنْ هذا؟",
  "translit": "man hādhā?",
  "meaning": "Who is this?",
  "order": 6,
  "notes": "مَنْ means \"who\" — used for people.\nIn classical Arabic, mostly animate beings (people and some animals) are referred to with مَنْ; objects use ما.\nIn this section the same demonstrative هذا applies to people just as it did to objects.",
  "examples": [
    { "prompt": "مَنْ هذا؟", "tokens": [{ "ar": "مَنْ", "en": "who" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا طَبِيبٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "طَبِيبٌ", "en": "(is) a doctor" }] },
    { "prompt": "مَنْ هذا؟", "tokens": [{ "ar": "مَنْ", "en": "who" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا وَلَدٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "وَلَدٌ", "en": "(is) a boy" }] },
    { "prompt": "مَنْ هذا؟", "tokens": [{ "ar": "مَنْ", "en": "who" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا طَالِبٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "طَالِبٌ", "en": "(is) a student" }] },
    { "prompt": "أهذا وَلَدٌ؟", "tokens": [{ "ar": "أهذا", "en": "is this" }, { "ar": "وَلَدٌ؟", "en": "(a) boy?" }],
      "answer": "لا، هذا رَجُلٌ.", "answerTokens": [{ "ar": "لا،", "en": "no," }, { "ar": "هذا", "en": "this" }, { "ar": "رَجُلٌ", "en": "(is) a man" }] },
    { "prompt": "مَنْ هذا؟", "tokens": [{ "ar": "مَنْ", "en": "who" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا تَاجِرٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "تَاجِرٌ", "en": "(is) a merchant" }] },
    { "prompt": "أهذا كَلْبٌ؟", "tokens": [{ "ar": "أهذا", "en": "is this" }, { "ar": "كَلْبٌ؟", "en": "(a) dog?" }],
      "answer": "لا، هذا قِطٌّ.", "answerTokens": [{ "ar": "لا،", "en": "no," }, { "ar": "هذا", "en": "this" }, { "ar": "قِطٌّ", "en": "(is) a cat" }] },
    { "prompt": "أهذا حِمَارٌ؟", "tokens": [{ "ar": "أهذا", "en": "is this" }, { "ar": "حِمَارٌ؟", "en": "(a) donkey?" }],
      "answer": "لا، هذا حِصَانٌ.", "answerTokens": [{ "ar": "لا،", "en": "no," }, { "ar": "هذا", "en": "this" }, { "ar": "حِصَانٌ", "en": "(is) a horse" }] },
    { "prompt": "وما هذا؟", "tokens": [{ "ar": "وما", "en": "and what" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا جَمَلٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "جَمَلٌ", "en": "(is) a camel" }] },
    { "prompt": "ما هذا؟", "tokens": [{ "ar": "ما", "en": "what" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا دِيكٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "دِيكٌ", "en": "(is) a rooster" }] },
    { "prompt": "مَنْ هذا؟", "tokens": [{ "ar": "مَنْ", "en": "who" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا مُدَرِّسٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "مُدَرِّسٌ", "en": "(is) a teacher" }] },
    { "prompt": "أهذا قَمِيصٌ؟", "tokens": [{ "ar": "أهذا", "en": "is this" }, { "ar": "قَمِيصٌ؟", "en": "(a) shirt?" }],
      "answer": "لا، هذا مِنْدِيلٌ.", "answerTokens": [{ "ar": "لا،", "en": "no," }, { "ar": "هذا", "en": "this" }, { "ar": "مِنْدِيلٌ", "en": "(is) a handkerchief" }] }
  ],
  "vocab": [
    { "arabic": "طَبِيبٌ", "translit": "ṭabībun", "meaning": "doctor", "gender": "m", "plural": "أَطِبَّاء", "pluralTranslit": "aṭibbā'" },
    { "arabic": "وَلَدٌ", "translit": "waladun", "meaning": "boy", "gender": "m", "plural": "أَوْلَاد", "pluralTranslit": "awlād" },
    { "arabic": "طَالِبٌ", "translit": "ṭālibun", "meaning": "student", "gender": "m", "plural": "طُلَّاب", "pluralTranslit": "ṭullāb" },
    { "arabic": "رَجُلٌ", "translit": "rajulun", "meaning": "man", "gender": "m", "plural": "رِجَال", "pluralTranslit": "rijāl" },
    { "arabic": "تَاجِرٌ", "translit": "tājirun", "meaning": "merchant", "gender": "m", "plural": "تُجَّار", "pluralTranslit": "tujjār" },
    { "arabic": "كَلْبٌ", "translit": "kalbun", "meaning": "dog", "gender": "m", "plural": "كِلَاب", "pluralTranslit": "kilāb" },
    { "arabic": "قِطٌّ", "translit": "qiṭṭun", "meaning": "cat", "gender": "m", "plural": "قِطَط", "pluralTranslit": "qiṭaṭ" },
    { "arabic": "حِمَارٌ", "translit": "ḥimārun", "meaning": "donkey", "gender": "m", "plural": "حَمِير", "pluralTranslit": "ḥamīr" },
    { "arabic": "حِصَانٌ", "translit": "ḥiṣānun", "meaning": "horse", "gender": "m", "plural": "خُيُول", "pluralTranslit": "khuyūl" },
    { "arabic": "جَمَلٌ", "translit": "jamalun", "meaning": "camel", "gender": "m", "plural": "جِمَال", "pluralTranslit": "jimāl" },
    { "arabic": "دِيكٌ", "translit": "dīkun", "meaning": "rooster", "gender": "m", "plural": "دُيُوك", "pluralTranslit": "duyūk" },
    { "arabic": "مُدَرِّسٌ", "translit": "mudarrisun", "meaning": "teacher", "gender": "m", "plural": "مُدَرِّسُون", "pluralTranslit": "mudarrisūn" },
    { "arabic": "مِنْدِيلٌ", "translit": "mindīlun", "meaning": "handkerchief", "gender": "m", "plural": "مَنَادِيل", "pluralTranslit": "manādīl" },
    { "arabic": "مَنْ", "translit": "man", "meaning": "who?" },
    { "arabic": "نَعَمْ", "translit": "na'am", "meaning": "yes" },
    { "arabic": "لا", "translit": "lā", "meaning": "no" }
  ]
},
