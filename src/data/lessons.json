    { "arabic": "مِفْتَاحٌ", "translit": "miftāḥun", "meaning": "key", "gender": "m", "plural": "مَفَاتيح", "pluralTranslit": "mafātīḥ" },
    { "arabic": "قَلَمٌ", "translit": "qalamun", "meaning": "pen", "gender": "m", "plural": "أَقْلام", "pluralTranslit": "aqlām" },
    { "arabic": "كِتَابٌ", "translit": "kitābun", "meaning": "book", "gender": "m", "plural": "كُتُب", "pluralTranslit": "kutub" },
    { "arabic": "كُرْسِيٌّ", "translit": "kursiyyun", "meaning": "chair", "gender": "m", "plural": "كَرَاسِيّ", "pluralTranslit": "karāsī" },
