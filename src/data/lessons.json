{
  "type": "topic",
  "content": "هذا",
  "translit": "hādhā",
  "meaning": "this (masculine, near)",
  "order": 1,
  "notes": "هذا is the demonstrative pronoun for a single masculine object that is near.\nNouns appear with tanwīn (final ـٌ /-un/), the indefinite case ending — \"a door\", \"a mosque\", etc.\nUse هذا for masculine nouns; the feminine form (هذه) is introduced in Lesson 6.",
  "examples": [
    { "prompt": "هذا بَابٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "بَابٌ", "en": "(is) a door" }] },
    { "prompt": "هذا مَسْجِدٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "مَسْجِدٌ", "en": "(is) a mosque" }] },
    { "prompt": "هذا بَيْتٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "بَيْتٌ", "en": "(is) a house" }] },
    { "prompt": "هذا مِفْتَاحٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "مِفْتَاحٌ", "en": "(is) a key" }] },
    { "prompt": "هذا قَلَمٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "قَلَمٌ", "en": "(is) a pen" }] },
    { "prompt": "هذا كِتَابٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "كِتَابٌ", "en": "(is) a book" }] },
    { "prompt": "هذا كُرْسِيٌّ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "كُرْسِيٌّ", "en": "(is) a chair" }] },
    { "prompt": "هذا سَرِيرٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "سَرِيرٌ", "en": "(is) a bed" }] },
    { "prompt": "هذا مَكْتَبٌ.", "tokens": [{ "ar": "هذا", "en": "this" }, { "ar": "مَكْتَبٌ", "en": "(is) a desk" }] }
  ],
  "vocab": [
    { "arabic": "بَابٌ", "translit": "bābun", "meaning": "door", "gender": "m", "plural": "أَبْوَاب", "pluralTranslit": "abwāb" },
    { "arabic": "مَسْجِدٌ", "translit": "masjidun", "meaning": "mosque", "gender": "m", "plural": "مَسَاجِد", "pluralTranslit": "masājid" },
