{
  "type": "question",
  "content": "ما هذا؟",
  "translit": "mā hādhā?",
  "meaning": "What is this?",
  "order": 2,
  "notes": "ما means \"what\" when asking about non-human things.\nThe prefix أ at the start of a sentence (أهذا...؟) turns it into a yes/no question (\"is this...?\").\nAnswers use نَعَمْ (yes) or لا (no).",
  "examples": [
    { "prompt": "ما هذا؟", "tokens": [{ "ar": "ما", "en": "what" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا بَيْتٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "بَيْتٌ", "en": "(is) a house" }] },
    { "prompt": "أهذا بَيْتٌ؟", "tokens": [{ "ar": "أهذا", "en": "is this" }, { "ar": "بَيْتٌ؟", "en": "(a) house?" }],
      "answer": "نَعَمْ، هذا بَيْتٌ.", "answerTokens": [{ "ar": "نَعَمْ،", "en": "yes," }, { "ar": "هذا", "en": "this" }, { "ar": "بَيْتٌ", "en": "(is) a house" }] },
    { "prompt": "ما هذا؟", "tokens": [{ "ar": "ما", "en": "what" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا قَمِيصٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "قَمِيصٌ", "en": "(is) a shirt" }] },
    { "prompt": "أهذا سَرِيرٌ؟", "tokens": [{ "ar": "أهذا", "en": "is this" }, { "ar": "سَرِيرٌ؟", "en": "(a) bed?" }],
      "answer": "لا، هذا كُرْسِيٌّ.", "answerTokens": [{ "ar": "لا،", "en": "no," }, { "ar": "هذا", "en": "this" }, { "ar": "كُرْسِيٌّ", "en": "(is) a chair" }] },
    { "prompt": "أهذا مِفْتَاحٌ؟", "tokens": [{ "ar": "أهذا", "en": "is this" }, { "ar": "مِفْتَاحٌ؟", "en": "(a) key?" }],
      "answer": "لا، هذا قَلَمٌ.", "answerTokens": [{ "ar": "لا،", "en": "no," }, { "ar": "هذا", "en": "this" }, { "ar": "قَلَمٌ", "en": "(is) a pen" }] },
    { "prompt": "ما هذا؟", "tokens": [{ "ar": "ما", "en": "what" }, { "ar": "هذا؟", "en": "(is) this?" }],
      "answer": "هذا نَجْمٌ.", "answerTokens": [{ "ar": "هذا", "en": "this" }, { "ar": "نَجْمٌ", "en": "(is) a star" }] }
  ],
  "vocab": [
    { "arabic": "قَمِيصٌ", "translit": "qamīṣun", "meaning": "shirt", "gender": "m", "plural": "قُمْصَان", "pluralTranslit": "qumṣān" },
    { "arabic": "نَجْمٌ", "translit": "najmun", "meaning": "star", "gender": "m", "plural": "نُجُوم", "pluralTranslit": "nujūm" }
  ]
},
